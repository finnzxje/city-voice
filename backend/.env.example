# ─── Database ────────────────────────────────────────────────────────────────
# (defaults match docker-compose.yml — only override if you change the compose file)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cityvoice
DB_USER=cityvoice
DB_PASSWORD=cityvoice_dev

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use different secrets for access and refresh.
JWT_ACCESS_SECRET=replace-with-a-very-long-random-string-32plus
JWT_REFRESH_SECRET=replace-with-another-long-random-string-32plus

# ─── Gmail SMTP ───────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your account password).
# Enable 2FA on your Google account, then generate at:
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ─── Default Admin Seed ───────────────────────────────────────────────────────
# Created on first startup if no user with this email exists.
# CHANGE THESE before deploying!
ADMIN_EMAIL=admin@cityvoice.vn
ADMIN_PASSWORD=Admin@123
