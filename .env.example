# CityVoice Backend – Environment Variables
# Copy this file to .env and fill in the real values.
# The .env file is gitignored and never committed.
# docker-compose.yml reads these automatically.

# ── JWT ────────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use a random generator in production.
JWT_ACCESS_SECRET=change-me-in-production-access-secret-32chars
JWT_REFRESH_SECRET=change-me-in-production-refresh-secret-32chars

# ── Mail (Gmail SMTP) ─────────────────────────────────────────────────────────
# Use an App Password from https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ── Admin Seed Account ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@cityvoice.vn
ADMIN_PASSWORD=Admin@123   # Change immediately after first login in production
